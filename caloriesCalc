<iframe 
  style="border: 1px solid #ccc; width: 300px; height: 150px; border-radius: 8px;"
  srcdoc="
    <html>
    <body style='font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0;'>
      <div style='text-align: center;'>
        <input type='number' id='v1' placeholder='Value' style='width: 60px;' oninput='calc()'>
        <span> &times; </span>
        <input type='number' id='v2' value='2' style='width: 60px;' oninput='calc()'>
        <p style='margin-top: 10px; font-weight: bold;'>Result: <span id='res'>0</span></p>
      </div>
      <script>
        function calc() {
          const n1 = document.getElementById('v1').value || 0;
          const n2 = document.getElementById('v2').value || 0;
          document.getElementById('res').innerText = n1 * n2;
        }
      </script>
    </body>
    </html>
  ">
</iframe>
